# Backend environment (FastAPI). Copy to backend/.env and fill in values.

# --- OpenAI ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Must match the embedding model's output dimension.
EMBEDDING_DIM=1536

# --- Qdrant (external server) ---
# Example: Qdrant running in WSL, reachable from Windows by its WSL IP.
QDRANT_URL=http://172.19.4.226:6333
# Set only if your Qdrant server requires an API key (Qdrant Cloud).
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=pdf_knowledge_base

# --- Storage ---
DATABASE_URL=sqlite:///./data/app.db
UPLOAD_DIR=./data/uploads

# --- Uploads / security ---
MAX_UPLOAD_MB=20
# Shared secret for the document-management and conversation endpoints.
# Must match MANAGEMENT_SECRET in the frontend env.
MANAGEMENT_SECRET=change-me

# --- CORS ---
# Comma-separated origins allowed to call the API directly (the widget host).
ALLOWED_ORIGINS=http://localhost:3000

# --- RAG behaviour ---
TOP_K=4
FALLBACK_CONTACT=our support team at support@example.com
USE_DEMO_CORPUS=true
