# Workspace-level ignores. Backend- and frontend-specific patterns live in
# backend/.gitignore and frontend/.gitignore respectively.

# Secrets (never commit)
.env
*.env
!.env.example

# Source/uploaded PDFs must never be committed, wherever they land
*.pdf

# Agent skills (.claude/skills/) are committed as real files; do not ignore.

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
